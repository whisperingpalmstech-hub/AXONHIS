# ─── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=axonhis
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=axonhis
DATABASE_URL=postgresql+asyncpg://axonhis:changeme_in_prod@postgres:5432/axonhis

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ─────────────────────────────────────────────────────────
SECRET_KEY=replace_with_64_char_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
BACKEND_CORS_ORIGINS=http://localhost:3000

# ─── AI / Voice ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...        # Used for Whisper STT + GPT-4o order extraction
LLM_MODEL=gpt-4o
STT_PROVIDER=whisper         # whisper | deepgram

# ─── Celery / Worker ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Frontend (Next.js public env) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
